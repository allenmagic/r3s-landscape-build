# Landscape Build Configuration

# Landscape Router Release Version
LANDSCAPE_VERSION="latest"

# GitHub Repository URL
LANDSCAPE_REPO="https://github.com/ThisSeanZhang/landscape"

# Kernel Configuration Mode
# set to "yes" to enable interactive kernel configuration menu and auto-save back to userpatches
# set to "no" to use existing config in userpatches without interactive menu
ENABLE_KERNEL_CONFIGURE="yes"
